# ATLAS Action Tracker — Environment Variables
# Copy this file to .env and fill in your values

# Supabase (required)
SUPABASE_URL=https://mnfovwxgmhacfljcpkio.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# Or use the anon key if RLS is disabled on atlas_ tables:
# SUPABASE_ANON_KEY=

# API Authentication (required for remote access)
ATLAS_API_TOKEN=

# Server
NODE_ENV=production
HOST=0.0.0.0
PORT=3001

# Cloudflare Access (optional, for tunnel auth)
TUNNEL_DOMAIN=
CF_TEAM_DOMAIN=
CF_ACCESS_AUD=

# CORS (optional, comma-separated origins)
ATLAS_ALLOWED_ORIGINS=
